    <DTS:Executable DTS:refId="Package\Execute SQL Task" DTS:CreationName="Microsoft.ExecuteSQLTask" DTS:Description="Execute SQL Task" DTS:DTSID="{D750FE46-3170-4A31-9AE3-9D83F2E90AE8}" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:LocaleID="-1" DTS:ObjectName="Execute SQL Task" DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; Â© 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1" DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:Connection="{C955E167-8359-48A9-9648-CAA029AF8B09}" SQLTask:BypassPrepare="False" SQLTask:SqlStatementSource="&#xA;USE Sakila_DW;&#xA;GO&#xA;&#xA;-- ============================================================&#xA;-- PHáº¦N 1: INSERT dÃ²ng Ä‘áº·c biá»‡t date_key = -1&#xA;-- DÃ¹ng cho return_date_key khi khÃ¡ch chÆ°a tráº£ Ä‘Ä©a (return_date IS NULL)&#xA;-- Cáº§n cÃ³ TRÆ¯á»šC khi load Fact_Sale Ä‘á»ƒ Lookup khÃ´ng bá»‹ lá»—i FK&#xA;-- ============================================================&#xA;&#xA;PRINT 'Báº¯t Ä‘áº§u PHáº¦N 1: Kiá»ƒm tra vÃ  insert dÃ²ng Ä‘áº·c biá»‡t date_key = -1...';&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.Dim_Date WHERE date_key = -1)&#xA;BEGIN&#xA;    INSERT INTO dw.Dim_Date (&#xA;        date_key,&#xA;        date,&#xA;        day_of_week,&#xA;        day_name,&#xA;        day_of_month,&#xA;        day_of_year,&#xA;        week_of_year,&#xA;        month_of_year,&#xA;        month_name,&#xA;        quarter_of_year,&#xA;        year,&#xA;        is_weekend,&#xA;        is_special_day,&#xA;        special_day&#xA;    )&#xA;    VALUES (&#xA;        -1,         -- date_key Ä‘áº·c biá»‡t&#xA;        NULL,       -- khÃ´ng cÃ³ ngÃ y thá»±c táº¿&#xA;        0,          -- day_of_week = 0 (khÃ´ng xÃ¡c Ä‘á»‹nh)&#xA;        'N/A',      -- day_name&#xA;        0,          -- day_of_month&#xA;        0,          -- day_of_year&#xA;        0,          -- week_of_year&#xA;        0,          -- month_of_year&#xA;        'N/A',      -- month_name&#xA;        0,          -- quarter_of_year&#xA;        0,          -- year&#xA;        0,          -- is_weekend&#xA;        0,          -- is_special_day&#xA;        N'ChÆ°a tráº£ Ä‘Ä©a'  -- special_day â€” mÃ´ táº£ nghiá»‡p vá»¥&#xA;    );&#xA;    PRINT '  â†’ ÄÃ£ insert dÃ²ng date_key = -1 (ChÆ°a tráº£ Ä‘Ä©a).';&#xA;END&#xA;ELSE&#xA;BEGIN&#xA;    PRINT '  â†’ DÃ²ng date_key = -1 Ä‘Ã£ tá»“n táº¡i, bá» qua insert.';&#xA;END&#xA;&#xA;GO&#xA;&#xA;-- ============================================================&#xA;-- PHáº¦N 2: Sinh tá»± Ä‘á»™ng cÃ¡c ngÃ y tá»« 2000-01-01 Ä‘áº¿n 2030-12-31&#xA;-- LÆ°u Ã½: Chá»‰ xÃ³a date_key &gt; 0 Ä‘á»ƒ giá»¯ nguyÃªn dÃ²ng -1 á»Ÿ PHáº¦N 1&#xA;-- ============================================================&#xA;&#xA;PRINT '';&#xA;PRINT 'Báº¯t Ä‘áº§u PHáº¦N 2: Sinh dá»¯ liá»‡u Dim_Date 2000-01-01 â†’ 2030-12-31...';&#xA;&#xA;-- XÃ³a dá»¯ liá»‡u ngÃ y cÅ© (giá»¯ láº¡i dÃ²ng -1)&#xA;DELETE FROM dw.Dim_Date WHERE date_key &gt; 0;&#xA;PRINT '  â†’ ÄÃ£ xÃ³a dá»¯ liá»‡u cÅ© (date_key &gt; 0).';&#xA;&#xA;-- Khai bÃ¡o biáº¿n vÃ²ng láº·p&#xA;DECLARE @StartDate DATE = '2000-01-01';&#xA;DECLARE @EndDate   DATE = '2030-12-31';&#xA;DECLARE @Current   DATE = @StartDate;&#xA;&#xA;-- VÃ²ng láº·p sinh tá»«ng ngÃ y&#xA;WHILE @Current &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO dw.Dim_Date (&#xA;        date_key,&#xA;        date,&#xA;        day_of_week,&#xA;        day_name,&#xA;        day_of_month,&#xA;        day_of_year,&#xA;        week_of_year,&#xA;        month_of_year,&#xA;        month_name,&#xA;        quarter_of_year,&#xA;        year,&#xA;        is_weekend,&#xA;        is_special_day,&#xA;        special_day&#xA;    )&#xA;    VALUES (&#xA;        -- date_key: Ä‘á»‹nh dáº¡ng YYYYMMDD&#xA;        CAST(FORMAT(@Current, 'yyyyMMdd') AS INT),&#xA;&#xA;        -- date&#xA;        @Current,&#xA;&#xA;        -- day_of_week: 1=Sunday, 2=Monday ... 7=Saturday&#xA;        DATEPART(WEEKDAY, @Current),&#xA;&#xA;        -- day_name&#xA;        DATENAME(WEEKDAY, @Current),&#xA;&#xA;        -- day_of_month&#xA;        DAY(@Current),&#xA;&#xA;        -- day_of_year&#xA;        DATEPART(DAYOFYEAR, @Current),&#xA;&#xA;        -- week_of_year (ISO)&#xA;        DATEPART(ISO_WEEK, @Current),&#xA;&#xA;        -- month_of_year&#xA;        MONTH(@Current),&#xA;&#xA;        -- month_name&#xA;        DATENAME(MONTH, @Current),&#xA;&#xA;        -- quarter_of_year&#xA;        DATEPART(QUARTER, @Current),&#xA;&#xA;        -- year&#xA;        YEAR(@Current),&#xA;&#xA;        -- is_weekend: Thá»© 7 (7) hoáº·c Chá»§ Nháº­t (1)&#xA;        CASE WHEN DATEPART(WEEKDAY, @Current) IN (1, 7) THEN 1 ELSE 0 END,&#xA;&#xA;        -- is_special_day: NgÃ y lá»… Viá»‡t Nam&#xA;        CASE&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '01-01' THEN 1  -- Táº¿t DÆ°Æ¡ng lá»‹ch&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '04-30' THEN 1  -- Giáº£i phÃ³ng miá»n Nam&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '05-01' THEN 1  -- Quá»‘c táº¿ Lao Ä‘á»™ng&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '09-02' THEN 1  -- Quá»‘c khÃ¡nh&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '12-25' THEN 1  -- GiÃ¡ng sinh&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '11-24' THEN 1  -- NgÃ y VÄƒn HÃ³a Viá»‡t Nam&#xA;            ELSE 0&#xA;        END,&#xA;&#xA;        -- special_day&#xA;        CASE&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '01-01' THEN N'Táº¿t DÆ°Æ¡ng Lá»‹ch'&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '04-30' THEN N'NgÃ y Giáº£i PhÃ³ng Miá»n Nam'&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '05-01' THEN N'Quá»‘c Táº¿ Lao Äá»™ng'&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '09-02' THEN N'Quá»‘c KhÃ¡nh'&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '12-25' THEN N'GiÃ¡ng Sinh'&#xA;            WHEN FORMAT(@Current, 'MM-dd') = '11-24' THEN N'NgÃ y VÄƒn HÃ³a Viá»‡t Nam'&#xA;            ELSE NULL&#xA;        END&#xA;    );&#xA;&#xA;    SET @Current = DATEADD(DAY, 1, @Current);&#xA;END;&#xA;&#xA;PRINT 'PHáº¦N 2 hoÃ n thÃ nh.';&#xA;&#xA;-- Kiá»ƒm tra káº¿t quáº£ tá»•ng thá»ƒ&#xA;PRINT '';&#xA;PRINT '=== Kiá»ƒm tra káº¿t quáº£ ===';&#xA;SELECT&#xA;    COUNT(*)                                        AS tong_so_dong,&#xA;    COUNT(CASE WHEN date_key = -1 THEN 1 END)       AS dong_dac_biet,&#xA;    COUNT(CASE WHEN date_key &gt; 0  THEN 1 END)       AS dong_ngay_thuong,&#xA;    MIN(CASE WHEN date_key &gt; 0 THEN date END)       AS ngay_dau_tien,&#xA;    MAX(CASE WHEN date_key &gt; 0 THEN date END)       AS ngay_cuoi_cung,&#xA;    COUNT(CASE WHEN is_special_day = 1 THEN 1 END)  AS so_ngay_le&#xA;FROM dw.Dim_Date;&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
